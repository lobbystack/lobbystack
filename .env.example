# Shared
NODE_ENV=development
DEPLOYMENT_MODE=development
APP_BASE_URL=http://localhost:5173
SITE_URL=http://localhost:5173
VOICE_GATEWAY_BASE_URL=https://your-public-voice-gateway.example.com
VOICE_GATEWAY_TRUST_PROXY=false
PORT=3001
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SITE_URL=https://your-deployment.convex.site
CONVEX_DEPLOYMENT=

# Web client
VITE_APP_NAME=LobbyStack
VITE_DEPLOYMENT_MODE=development
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://ts.lobbystack.com
VITE_POSTHOG_UI_HOST=https://us.posthog.com
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# In local dev, leave this unset so it defaults to http://127.0.0.1:3001/web-call/sessions (requires `pnpm dev:voice`).
# VITE_WEB_CALL_ENDPOINT=https://voice.lobbystack.com/web-call/sessions

# Landing site
PUBLIC_POSTHOG_ENABLED=false
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://ts.lobbystack.com
PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
PUBLIC_WEB_CALL_ENDPOINT=https://voice.lobbystack.com/web-call/sessions
PUBLIC_WEB_CALL_BUSINESS_SLUG=lobbystack-mp35s9y1
INDEXNOW_KEY=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Auth / app secrets
SESSION_ENCRYPTION_KEY=change-me
INTERNAL_SERVICE_TOKEN=change-me
JWT_PRIVATE_KEY=
JWKS=
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_ALERT_SMS_FROM=
TWILIO_VERIFY_SERVICE_SID=

# Polar billing
POLAR_SERVER=production
POLAR_ORGANIZATION_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_STARTER_MONTHLY_PRODUCT_ID=fc07b74d-3dc7-4efb-9270-be74de48e187
POLAR_STARTER_ANNUAL_PRODUCT_ID=40145a2c-9cfd-491c-8cec-b6aa63b6b52f
POLAR_PRO_MONTHLY_PRODUCT_ID=f1e1fbeb-a0d5-4f40-bb98-b27d70a2c0d3
POLAR_PRO_ANNUAL_PRODUCT_ID=747a648b-0939-4626-967f-93941bcff296
POLAR_STARTER_MONTHLY_AI_SMS_PRODUCT_ID=
POLAR_STARTER_ANNUAL_AI_SMS_PRODUCT_ID=
POLAR_PRO_MONTHLY_AI_SMS_PRODUCT_ID=
POLAR_PRO_ANNUAL_AI_SMS_PRODUCT_ID=
# Legacy fallback for the Pro monthly subscription product after AI SMS is enabled.
POLAR_PRO_AI_SMS_PRODUCT_ID=
# One-time AI SMS setup fee checkout product ($19).
POLAR_AI_SMS_SETUP_PRODUCT_ID=
# Optional: legacy separate AI SMS subscription product recognition only.
POLAR_AI_SMS_ADDON_PRODUCT_ID=

# OpenAI Realtime Voice
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
# Optional PostHog cost fallback for realtime models that are not auto-priced by model name.
# Values are USD per token, not per million tokens.
# The generic input/output vars are legacy text-style fallbacks.
OPENAI_REALTIME_INPUT_TOKEN_PRICE_USD=
OPENAI_REALTIME_OUTPUT_TOKEN_PRICE_USD=
OPENAI_REALTIME_TEXT_INPUT_TOKEN_PRICE_USD=
OPENAI_REALTIME_AUDIO_INPUT_TOKEN_PRICE_USD=
OPENAI_REALTIME_TEXT_OUTPUT_TOKEN_PRICE_USD=
OPENAI_REALTIME_AUDIO_OUTPUT_TOKEN_PRICE_USD=
OPENAI_REALTIME_CACHED_INPUT_TOKEN_PRICE_USD=
OPENAI_REALTIME_VOICE=marin
# Web voice CORS: public origins for production-like configs. Include the dashboard app origin plus the landing site.
# With DEPLOYMENT_MODE=development (voice-gateway default), localhost is still allowed for browser origins.
# If you run with DEPLOYMENT_MODE=cloud locally, append http://localhost:4321,http://127.0.0.1:4321 for local landing.
WEB_CALL_ALLOWED_ORIGINS=https://app.lobbystack.com,https://lobbystack.com,https://www.lobbystack.com
# Optional shared token configured on both Convex and the voice gateway for elevated dashboard test-call limits.
DASHBOARD_TEST_CALL_TOKEN=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# Optional PostHog cost fallback for separate input transcription model usage.
# Values are USD per token, not per million tokens.
OPENAI_TRANSCRIPTION_INPUT_TOKEN_PRICE_USD=
OPENAI_TRANSCRIPTION_OUTPUT_TOKEN_PRICE_USD=

# Gemini Text / Embeddings
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Website ingestion
FIRECRAWL_API_KEY=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Microsoft Graph
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=

# Email
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@example.com
FEEDBACK_TO_EMAIL=feedback@example.com

# Telemetry
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PRIVACY_MODE=true
POSTHOG_CLI_API_KEY=
POSTHOG_CLI_PROJECT_ID=
POSTHOG_CLI_HOST=https://us.posthog.com
POSTHOG_RELEASE_NAME=@lobbystack/web
POSTHOG_RELEASE_VERSION=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
UNIT_ECONOMICS_MONTHLY_CONVEX_COST_USD=
UNIT_ECONOMICS_MONTHLY_FLY_COST_USD=
