{
  "name": "lobbystack",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "1.19.13",
      "@xmldom/xmldom": "0.8.13",
      "axios": "1.15.2",
      "basic-ftp": "5.3.1",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5",
      "@mintlify/previewing": "4.0.1096",
      "@mintlify/scraping>zod": "3.25.76",
      "@mintlify/validation>zod": "3.25.76",
      "dompurify": "3.4.0",
      "follow-redirects": "1.16.0",
      "fast-uri": "3.1.2",
      "hono": "4.12.18",
      "ip-address": "10.1.1",
      "js-yaml": "4.1.1",
      "lodash": "4.18.1",
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.0",
      "picomatch": "2.3.2",
      "postcss": "8.5.10",
      "protobufjs@<7.5.6": "7.5.6",
      "protobufjs@>=8.0.0 <8.0.2": "8.0.2",
      "tar": "7.5.15",
      "uuid": "14.0.0"
    },
    "supportedArchitectures": {
      "os": [
        "current",
        "linux"
      ],
      "cpu": [
        "current",
        "arm64"
      ],
      "libc": [
        "current",
        "glibc"
      ]
    },
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "patchedDependencies": {
      "@mintlify/previewing@4.0.1096": "patches/@mintlify__previewing@4.0.1096.patch",
      "front-matter@4.0.2": "patches/front-matter@4.0.2.patch"
    }
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@convex-dev/action-retrier": "latest",
    "@convex-dev/agent": "latest",
    "@convex-dev/auth": "latest",
    "@convex-dev/crons": "latest",
    "@convex-dev/persistent-text-streaming": "0.3.2",
    "@convex-dev/polar": "^0.9.0",
    "@convex-dev/rag": "latest",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/resend": "^0.2.3",
    "@convex-dev/workflow": "latest",
    "@convex-dev/workpool": "latest",
    "@polar-sh/sdk": "^0.47.0",
    "ai": "latest",
    "convex": "^1.37.0",
    "convex-firecrawl-scrape": "^0.1.3",
    "firecrawl": "^4.20.1",
    "jimp": "^1.6.1",
    "luxon": "^3.7.2",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "5.4.296",
    "pureimage": "^0.4.18",
    "sharp": "^0.34.4",
    "tesseract.js": "^7.0.0",
    "twilio": "^5.12.2",
    "zod": "^3.24.2"
  },
  "scripts": {
    "dev": "concurrently -n convex,web,voice \"pnpm dev:convex\" \"pnpm dev:web\" \"pnpm dev:voice\"",
    "dev:convex": "convex dev",
    "docs:dev": "pnpm --filter @lobbystack/docs dev",
    "docs:dev:no-open": "pnpm --filter @lobbystack/docs dev:no-open",
    "docs:validate": "pnpm --filter @lobbystack/docs validate",
    "docs:broken-links": "pnpm --filter @lobbystack/docs broken-links",
    "dev:web": "pnpm --filter @lobbystack/web dev",
    "dev:voice": "pnpm --filter @lobbystack/voice-gateway dev",
    "posthog:sourcemaps": "pnpm --filter @lobbystack/web posthog:sourcemaps",
    "dev:onboarding:website": "tsx scripts/prepare-onboarding-website.ts",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck && pnpm typecheck:convex",
    "typecheck:convex": "tsc -p convex/tsconfig.json --noEmit",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test && pnpm test:convex",
    "test:convex": "vitest run --config convex/vitest.config.ts",
    "seed:demo": "tsx scripts/seed-demo.ts"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.0.0",
    "concurrently": "^9.1.2",
    "convex-test": "^0.0.44",
    "lucia": "^3.2.2",
    "playwright": "^1.58.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2"
  }
}
