{
  "name": "ai-receptionist",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.7"
    },
    "supportedArchitectures": {
      "os": [
        "current",
        "linux"
      ],
      "cpu": [
        "current",
        "arm64"
      ],
      "libc": [
        "current",
        "glibc"
      ]
    },
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@convex-dev/action-retrier": "latest",
    "@convex-dev/agent": "latest",
    "@convex-dev/auth": "latest",
    "@convex-dev/crons": "latest",
    "@convex-dev/persistent-text-streaming": "latest",
    "@convex-dev/rag": "latest",
    "@convex-dev/resend": "^0.2.3",
    "@convex-dev/workflow": "latest",
    "@convex-dev/workpool": "latest",
    "ai": "latest",
    "convex": "^1.31.2",
    "jimp": "^1.6.0",
    "luxon": "^3.7.2",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "5.4.296",
    "pureimage": "^0.4.18",
    "sharp": "^0.34.4",
    "tesseract.js": "^7.0.0",
    "twilio": "^5.12.2",
    "zod": "^3.24.2"
  },
  "scripts": {
    "dev": "concurrently -n convex,web,voice \"pnpm dev:convex\" \"pnpm dev:web\" \"pnpm dev:voice\"",
    "dev:convex": "convex dev",
    "dev:web": "pnpm --filter @ai-receptionist/web dev",
    "dev:voice": "pnpm --filter @ai-receptionist/voice-gateway dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "seed:demo": "tsx scripts/seed-demo.ts"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.0.0",
    "concurrently": "^9.1.2",
    "convex-test": "^0.0.41",
    "playwright": "^1.58.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
