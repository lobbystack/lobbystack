# LobbyStack self-hosted Docker Compose environment.
# Copy this file to .env.self-hosted and replace every placeholder before launch.

# Compose / image settings
COMPOSE_PROJECT_NAME=lobbystack
# Pin these after your first successful deploy for reproducible upgrades.
CONVEX_BACKEND_IMAGE_TAG=latest
CONVEX_DASHBOARD_IMAGE_TAG=latest

# Local direct-access ports for first-run validation.
WEB_PORT=8080
VOICE_GATEWAY_PORT=3001
CONVEX_PORT=3210
CONVEX_SITE_PROXY_PORT=3211
CONVEX_DASHBOARD_PORT=6791
# Keep 127.0.0.1 during localhost smoke; set 0.0.0.0 before exposing public HTTPS ingress.
CADDY_BIND_ADDRESS=127.0.0.1

# Public hostnames routed by docker/caddy/Caddyfile.
# For localhost smoke testing, use localhost for every hostname below.
# For production, replace with your public DNS hostnames.
ACME_EMAIL=admin@example.com
APP_HOSTNAME=app.example.com
VOICE_HOSTNAME=voice.example.com
CONVEX_HOSTNAME=convex.example.com
CONVEX_SITE_HOSTNAME=convex-site.example.com

# Public runtime URLs. These are also build-time values for apps/web.
APP_BASE_URL=https://app.example.com
SITE_URL=https://app.example.com
VOICE_GATEWAY_BASE_URL=https://voice.example.com
CONVEX_URL=https://convex.example.com
CONVEX_SITE_URL=https://convex-site.example.com
CONVEX_CLOUD_ORIGIN=https://convex.example.com
CONVEX_SITE_ORIGIN=https://convex-site.example.com
CONVEX_DASHBOARD_DEPLOYMENT_URL=https://convex.example.com

# Convex CLI access. Generate the admin key after the backend starts:
#   docker compose -f docker-compose.self-hosted.yml --env-file .env.self-hosted exec convex-backend ./generate_admin_key.sh
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=

# Shared app runtime
NODE_ENV=production
DEPLOYMENT_MODE=self_hosted_standard
VITE_APP_NAME=LobbyStack
VITE_DEPLOYMENT_MODE=self_hosted_standard
VOICE_GATEWAY_TRUST_PROXY=true

# Generate these with: pnpm self-hosted:secrets
SESSION_ENCRYPTION_KEY=change-me-generate-with-pnpm-self-hosted-secrets
INTERNAL_SERVICE_TOKEN=change-me-generate-with-pnpm-self-hosted-secrets
INSTANCE_SECRET=change-me-generate-with-pnpm-self-hosted-secrets
JWT_PRIVATE_KEY=
JWKS=

# Web client analytics and abuse controls
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_POSTHOG_UI_HOST=https://us.posthog.com
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Twilio
NUMBER_CLAIM_TOKEN_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_ALERT_SMS_FROM=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_PRIMARY_CUSTOMER_PROFILE_SID=
TWILIO_A2P_STATUS_EMAIL=
TWILIO_A2P_TRUST_PRODUCT_POLICY_SID=
TWILIO_A2P_REQUEST_DELAY_MS=

# OpenAI Realtime Voice
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_INPUT_TOKEN_PRICE_USD=
OPENAI_REALTIME_OUTPUT_TOKEN_PRICE_USD=
OPENAI_REALTIME_TEXT_INPUT_TOKEN_PRICE_USD=
OPENAI_REALTIME_AUDIO_INPUT_TOKEN_PRICE_USD=
OPENAI_REALTIME_TEXT_OUTPUT_TOKEN_PRICE_USD=
OPENAI_REALTIME_AUDIO_OUTPUT_TOKEN_PRICE_USD=
OPENAI_REALTIME_CACHED_INPUT_TOKEN_PRICE_USD=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSCRIPTION_INPUT_TOKEN_PRICE_USD=
OPENAI_TRANSCRIPTION_OUTPUT_TOKEN_PRICE_USD=
# For localhost smoke use http://127.0.0.1:8080; for production use your public app URL.
WEB_CALL_ALLOWED_ORIGINS=https://app.example.com

# Gemini Text / Embeddings
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Website ingestion
FIRECRAWL_API_KEY=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://convex-site.example.com/integrations/google/callback

# Microsoft Graph
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=

# Email
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@example.com
FEEDBACK_TO_EMAIL=feedback@example.com

# Optional hosted billing integration. Most self-hosted installs can leave this blank.
POLAR_SERVER=production
POLAR_ORGANIZATION_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRO_PRODUCT_ID=
POLAR_STARTER_MONTHLY_AI_SMS_PRODUCT_ID=
POLAR_STARTER_ANNUAL_AI_SMS_PRODUCT_ID=
POLAR_PRO_MONTHLY_AI_SMS_PRODUCT_ID=
POLAR_PRO_ANNUAL_AI_SMS_PRODUCT_ID=
POLAR_PRO_AI_SMS_PRODUCT_ID=
POLAR_AI_SMS_SETUP_PRODUCT_ID=
POLAR_AI_SMS_ADDON_PRODUCT_ID=

# Telemetry
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PRIVACY_MODE=true
POSTHOG_CLI_API_KEY=
POSTHOG_CLI_PROJECT_ID=
POSTHOG_CLI_HOST=https://us.posthog.com
POSTHOG_RELEASE_NAME=@lobbystack/web
POSTHOG_RELEASE_VERSION=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
UNIT_ECONOMICS_MONTHLY_CONVEX_COST_USD=
UNIT_ECONOMICS_MONTHLY_FLY_COST_USD=

# Optional Convex backend storage/database hardening knobs.
# OPE-25's default is single-host SQLite with Docker volumes.
DATABASE_URL=
POSTGRES_URL=
MYSQL_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_ENDPOINT_URL=
S3_STORAGE_EXPORTS_BUCKET=
S3_STORAGE_FILES_BUCKET=
S3_STORAGE_MODULES_BUCKET=
S3_STORAGE_SEARCH_BUCKET=
S3_STORAGE_SNAPSHOT_IMPORTS_BUCKET=
DISABLE_METRICS_ENDPOINT=true
DOCUMENT_RETENTION_DELAY=172800
RUST_LOG=info
