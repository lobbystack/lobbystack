---
import Layout from "@/layouts/main.astro"
import { Navbar } from "@/components/Navbar"
import { Footer } from "@/components/Footer"
import { FeaturesCtaSection } from "@/components/features/FeaturesCtaSection"
import { render } from "astro:content"
import type { BlogEntry } from "@/lib/blog"
import { blogPath } from "@/lib/blog"
import {
  blogJsonLd,
  blogPostingJsonLd,
  breadcrumbJsonLd,
  imageObjectJsonLd,
  organizationJsonLd,
  plainTextFromMarkdown,
  webSiteJsonLd,
} from "@/lib/seo"
import {
  assertLocale,
  getCopy,
  localizePath,
  type Locale,
} from "@/i18n"

interface Props {
  entry: BlogEntry
  locale?: Locale
}

const { entry } = Astro.props
const locale = assertLocale(
  Astro.props.locale ?? Astro.currentLocale ?? entry.data.locale
)
const copy = getCopy(locale)
const { Content } = await render(entry)

const canonicalPath = blogPath(entry, locale)
const publishedTime = entry.data.pubDate.toISOString()
const articleBody = plainTextFromMarkdown(entry.body)
const dateLocale = locale === "fr" ? "fr-FR" : "en-US"
const pageCopy = {
  en: {
    titleSuffix: "LobbyStack Blog",
  },
  fr: {
    titleSuffix: "Blog Réceptionniste IA",
  },
} satisfies Record<Locale, { titleSuffix: string }>
---

<Layout
  seo={{
    title: `${entry.data.title} - ${pageCopy[locale].titleSuffix}`,
    description: entry.data.description,
    canonicalPath,
    locale,
    image: entry.data.coverImage,
    imageAlt: entry.data.title,
    type: "article",
    publishedTime,
    modifiedTime: publishedTime,
    author: entry.data.author,
    jsonLd: [
      organizationJsonLd({ locale }),
      webSiteJsonLd({ locale }),
      blogJsonLd({ locale, path: localizePath(locale, "/blog/") }),
      imageObjectJsonLd({
        path: canonicalPath,
        image: entry.data.coverImage,
        alt: entry.data.title,
        width: 1672,
        height: 941,
      }),
      blogPostingJsonLd({
        title: entry.data.title,
        description: entry.data.description,
        path: canonicalPath,
        image: entry.data.coverImage,
        author: entry.data.author,
        publishedTime,
        modifiedTime: publishedTime,
        articleBody,
        category: entry.data.category,
        locale,
      }),
      breadcrumbJsonLd([
        { name: copy.common.home, path: localizePath(locale, "/") },
        { name: "Blog", path: localizePath(locale, "/blog/") },
        { name: entry.data.title, path: canonicalPath },
      ]),
    ],
  }}
>
  <Navbar locale={locale} />

  <article
    id="main-content"
    class="min-h-screen bg-background pb-24 text-foreground"
  >
    <div class="mx-auto max-w-[760px] px-6 pt-24">
      <header class="mb-10">
        <h1 class="display-heading mb-6 text-foreground">
          {entry.data.title}
        </h1>

        <div class="flex items-center gap-4">
          {
            entry.data.category && (
              <span class="rounded-md border border-border/60 px-2.5 py-1 font-mono text-[0.6875rem] text-muted-foreground">
                {entry.data.category}
              </span>
            )
          }
          <time
            class="text-xs font-medium text-muted-foreground"
            datetime={entry.data.pubDate.toISOString()}
          >
            {
              entry.data.pubDate.toLocaleDateString(dateLocale, {
                day: "numeric",
                month: "short",
                year: "numeric",
              })
            }
          </time>
        </div>
      </header>

      {
        entry.data.coverImage && (
          <div class="mb-12 aspect-[16/9] overflow-hidden rounded-2xl border border-border/30 bg-muted shadow-sm">
            <img
              src={entry.data.coverImage}
              alt={entry.data.title}
              width="1672"
              height="941"
              class="h-full w-full object-contain"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        )
      }

      <div class="blog-copy max-w-none">
        <Content />
      </div>
    </div>
  </article>

  <FeaturesCtaSection locale={locale} />
  <Footer locale={locale} />
</Layout>
