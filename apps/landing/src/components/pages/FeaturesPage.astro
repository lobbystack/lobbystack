---
import Layout from "@/layouts/main.astro"
import { Navbar } from "@/components/Navbar"
import { FeaturesHero } from "@/components/features/FeaturesHero"
import { FeatureWall } from "@/components/features/FeatureWall"
import { IncludedOnEveryPlan } from "@/components/features/IncludedOnEveryPlan"
import { FeaturesCtaSection } from "@/components/features/FeaturesCtaSection"
import { Footer } from "@/components/Footer"
import {
  breadcrumbJsonLd,
  organizationJsonLd,
  webSiteJsonLd,
  absoluteUrl,
} from "@/lib/seo"
import { assertLocale, getCopy, getRouteSeo, localizePath, type Locale } from "@/i18n"

interface Props {
  locale?: Locale
}

const locale = assertLocale(Astro.props.locale ?? Astro.currentLocale)
const copy = getCopy(locale)
const canonicalPath = localizePath(locale, "/features/")
const seo = getRouteSeo({ locale, path: "/features/" })
---

<Layout
  seo={{
    ...seo,
    canonicalPath,
    locale,
    jsonLd: [
      organizationJsonLd({ locale }),
      webSiteJsonLd({ locale }),
      breadcrumbJsonLd([
        { name: copy.common.home, path: localizePath(locale, "/") },
        { name: locale === "fr" ? "Fonctionnalites" : "Features", path: canonicalPath },
      ]),
      {
        "@context": "https://schema.org",
        "@type": "WebPage",
        "@id": absoluteUrl(`${canonicalPath}#webpage`),
        name: seo?.title,
        url: absoluteUrl(canonicalPath),
        description: seo?.description,
        inLanguage: locale,
        isPartOf: {
          "@id": absoluteUrl("/#website"),
        },
      },
    ],
  }}
>
  <Navbar locale={locale} />
  <main>
    <FeaturesHero locale={locale} />
    <FeatureWall locale={locale} />
    <IncludedOnEveryPlan locale={locale} />
    <FeaturesCtaSection locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>

