---
import Layout from "@/layouts/main.astro"
import { Navbar } from "@/components/Navbar"
import { Footer } from "@/components/Footer"
import { absoluteUrl, breadcrumbJsonLd, organizationJsonLd } from "@/lib/seo"
import { assertLocale, getCopy, getRouteSeo, localizePath, type Locale } from "@/i18n"

type LegalKind = "privacy" | "terms"

interface Props {
  kind: LegalKind
  locale?: Locale
}

const { kind } = Astro.props
const locale = assertLocale(Astro.props.locale ?? Astro.currentLocale)
const copy = getCopy(locale)
const basePath = kind === "privacy" ? "/privacy/" : "/terms/"
const canonicalPath = localizePath(locale, basePath)
const routeSeo = getRouteSeo({ locale, path: basePath })

const legalCopy = {
  fr: {
    privacy: {
      updated: "Derniere mise a jour : 11 mai 2026",
      h1: "Politique de confidentialite",
      intro:
        "Cette Politique explique comment Lobbystack Inc. collecte, utilise, divulgue et protege les renseignements personnels lorsque vous visitez notre site, utilisez LobbyStack Cloud, communiquez par appels ou SMS alimentes par LobbyStack, contactez le support ou interagissez avec nos services.",
      notice:
        "Avis de langue : cette traduction francaise est fournie pour faciliter la lecture. En cas de conflit, la version anglaise controle, sauf exigence contraire de la loi applicable.",
      nav: [
        ["scope", "Portee"],
        ["collect", "Informations"],
        ["sms", "Consentement SMS"],
        ["use", "Utilisation"],
        ["share", "Partage"],
        ["retention", "Conservation"],
        ["rights", "Droits"],
        ["contact", "Contact"],
      ],
      sections: [
        {
          id: "scope",
          title: "1. Portee et notre role",
          paragraphs: [
            "LobbyStack fournit une plateforme de receptionniste IA pour entreprises couvrant appels, SMS, rendez-vous, routage, resumes, accueil client, reponses fondees sur la connaissance et flux de travail connexes.",
            "Nous pouvons traiter des renseignements personnels comme responsable pour notre site, nos comptes, notre facturation, notre securite, notre support et nos operations marketing. Nous pouvons aussi traiter des renseignements pour le compte de clients professionnels qui utilisent LobbyStack avec leurs propres appelants, clients, patients ou prospects.",
          ],
        },
        {
          id: "collect",
          title: "2. Informations que nous collectons",
          paragraphs: [
            "Nous collectons des informations de compte et d'entreprise, comme noms, adresses courriel, numeros de telephone, noms d'entreprise, roles, parametres, utilisateurs autorises, preferences de support et contacts de facturation.",
            "LobbyStack peut traiter numeros de telephone, identifiants d'appel, metadonnees, enregistrements, transcriptions, resumes, messages SMS, etats d'opt-in et opt-out, dossiers de consentement, profils de contacts, rendez-vous, notes, decisions de routage et resultats d'escalade.",
            "Les clients peuvent televerser ou connecter des informations d'entreprise, FAQ, services, prix, horaires, politiques, calendriers, documents, scripts, regles et autres materiaux utilises pour configurer la receptionniste IA.",
          ],
        },
        {
          id: "sms",
          title: "3. Consentement SMS et confidentialite des messages",
          paragraphs: [
            "LobbyStack prend en charge des SMS operationnels et conversationnels non marketing, comme reponses aux demandes, confirmations de rendez-vous, suivis d'appels manques, rappels, mises a jour de service et messages de support. La frequence varie. Des frais de message et de donnees peuvent s'appliquer.",
            "Les destinataires peuvent repondre STOP pour se desabonner et HELP pour obtenir de l'aide lorsque pris en charge, ou contacter support@lobbystack.com.",
            "Nous ne vendons, louons ni partageons les donnees d'opt-in SMS ou de consentement avec des tiers ou affilies pour leur marketing ou promotion.",
          ],
        },
        {
          id: "use",
          title: "4. Comment nous utilisons les informations",
          paragraphs: [
            "Nous utilisons les renseignements personnels pour fournir, exploiter, securiser, maintenir et ameliorer LobbyStack; repondre aux appels; traiter les SMS; produire des resumes; router des demandes; soutenir les rendez-vous; gerer comptes, authentification, facturation, taxes, plans, usage et support.",
            "Nous utilisons aussi ces informations pour traiter les opt-in et opt-out, respecter les exigences de telecommunications, prevenir spam, abus, fraude et incidents de securite, communiquer sur le service et respecter nos obligations legales, contractuelles, fournisseur, operateur et comptables.",
          ],
        },
        {
          id: "share",
          title: "5. Comment nous divulguons les informations",
          paragraphs: [
            "Nous divulguons les informations seulement lorsque necessaire, notamment a des fournisseurs de telephonie, SMS, transporteurs, numeros, modeles IA, traitement vocal, hebergement, base de donnees, stockage, infrastructure, surveillance, securite, paiement, facturation, support, communication, analytique et integrations connectees.",
            "Nous pouvons aussi divulguer des informations a des conseillers professionnels, auditeurs, assureurs et autorites legales ou reglementaires lorsque requis.",
          ],
        },
        {
          id: "retention",
          title: "6. Conservation et securite",
          paragraphs: [
            "Nous conservons les informations aussi longtemps que necessaire pour fournir les services, respecter nos obligations, resoudre les litiges, appliquer les accords, maintenir la securite et repondre aux exigences legales.",
            "Nous utilisons des mesures techniques, administratives et organisationnelles raisonnables pour proteger les informations, notamment controle d'acces, journalisation, chiffrement lorsque approprie et restrictions internes.",
          ],
        },
        {
          id: "rights",
          title: "7. Vos droits et choix",
          paragraphs: [
            "Selon votre lieu, vous pouvez avoir le droit de demander acces, correction, suppression, portabilite, opposition ou limitation de certains traitements. Vous pouvez aussi controler certains cookies et communications.",
            "Si une entreprise utilise LobbyStack pour communiquer avec vous, contactez d'abord cette entreprise pour les demandes relatives a ses propres pratiques.",
          ],
        },
        {
          id: "contact",
          title: "8. Nous contacter",
          paragraphs: [
            "Pour toute question sur cette Politique ou nos pratiques de confidentialite, contactez support@lobbystack.com.",
          ],
        },
      ],
    },
    terms: {
      updated: "Derniere mise a jour : 11 mai 2026",
      h1: "Conditions d'utilisation",
      intro:
        "Ces Conditions regissent l'acces et l'utilisation des services heberges, sites, forfaits payants, support, infrastructure geree et flux de receptionniste IA de LobbyStack.",
      notice:
        "Avis de langue : cette traduction francaise est fournie pour faciliter la lecture. En cas de conflit, la version anglaise controle, sauf exigence contraire de la loi applicable.",
      nav: [
        ["agreement", "Accord"],
        ["service", "Service"],
        ["accounts", "Comptes"],
        ["communications", "SMS et appels"],
        ["ai", "Limites IA"],
        ["billing", "Facturation"],
        ["data", "Donnees"],
        ["risk", "Risques"],
        ["law", "Droit"],
        ["contact", "Contact"],
      ],
      sections: [
        {
          id: "agreement",
          title: "1. Acceptation des Conditions",
          paragraphs: [
            "Ces Conditions constituent un accord legal entre vous et Lobbystack Inc. En accedant a notre site, en creant un compte, en utilisant le service heberge, en achetant un forfait ou en activant un module, vous acceptez ces Conditions.",
            "Si vous utilisez LobbyStack pour une entreprise ou organisation, vous declarez avoir l'autorite de lier cette entite.",
          ],
        },
        {
          id: "service",
          title: "2. Le service LobbyStack",
          paragraphs: [
            "LobbyStack est une plateforme de receptionniste IA pour appels, SMS, reservation, routage, resumes, capture de contacts, base de connaissances, suivis et communications connexes.",
            "Nous pouvons ameliorer, modifier, suspendre ou interrompre des parties du service. Certaines fonctionnalites peuvent etre en beta, limitees par des fournisseurs, des approbations, des plafonds d'usage ou des regions.",
          ],
        },
        {
          id: "accounts",
          title: "3. Comptes, utilisateurs et responsabilites client",
          paragraphs: [
            "Vous etes responsable de la securite des identifiants, de la gestion des utilisateurs, de l'exactitude des informations de compte et de facturation, et de toute activite sous votre compte.",
            "Vous etes responsable de configurer LobbyStack pour votre entreprise, notamment faits, services, prix, horaires, lieux, scripts, regles d'escalade, calendriers, connaissances, numeros de transfert et procedures humaines.",
          ],
        },
        {
          id: "communications",
          title: "4. Voix, SMS et conformite telecom",
          paragraphs: [
            "Les appels et SMS sont soumis aux regles des transporteurs, lois de telecommunications, lois anti-spam, conditions fournisseurs, enregistrements de campagnes, filtrage, disponibilite des numeros et restrictions d'usage.",
            "Vous etes responsable d'obtenir et documenter tous les consentements requis avant d'envoyer des appels ou messages via LobbyStack et de respecter les demandes de retrait.",
          ],
        },
        {
          id: "ai",
          title: "5. Limites de l'IA et revue humaine",
          paragraphs: [
            "LobbyStack utilise l'intelligence artificielle et l'automatisation. Les sorties IA peuvent etre incompletes, inexactes, retardees ou inadaptees a un usage particulier.",
            "LobbyStack ne remplace pas les services d'urgence, les conseils professionnels medicaux, juridiques, financiers ou de securite, ni le jugement humain pour les situations sensibles.",
          ],
        },
        {
          id: "billing",
          title: "6. Forfaits, facturation, taxes et remboursements",
          paragraphs: [
            "Les forfaits payants, modules, frais de configuration, frais d'usage, frais mesures et taxes sont decrits au paiement, dans l'application ou dans une commande applicable.",
            "Vous nous autorisez, ainsi que notre processeur de paiement, a debiter votre methode de paiement pour les montants dus. Sauf obligation legale ou accord ecrit, les frais ne sont pas remboursables.",
          ],
        },
        {
          id: "data",
          title: "7. Contenu client, donnees et propriete intellectuelle",
          paragraphs: [
            "Vous conservez la propriete de votre contenu professionnel, donnees clients, enregistrements, transcriptions, messages, connaissances, rendez-vous et autres contenus soumis au service.",
            "Vous accordez a LobbyStack les droits necessaires pour heberger, traiter, transmettre, afficher, analyser, securiser et utiliser ce contenu afin de fournir et ameliorer le service.",
          ],
        },
        {
          id: "risk",
          title: "8. Allocation des risques",
          paragraphs: [
            "Le service est fourni selon les conditions applicables et peut dependre de reseaux, fournisseurs et integrations tiers. Vous devez tester et surveiller les flux importants avant utilisation en production.",
          ],
        },
        {
          id: "law",
          title: "9. Droit applicable",
          paragraphs: [
            "Le droit applicable, les restrictions, limitations et procedures de resolution des litiges sont decrits dans la version anglaise complete des Conditions, qui controle sauf exigence contraire de la loi applicable.",
          ],
        },
        {
          id: "contact",
          title: "10. Contact",
          paragraphs: ["Pour toute question, contactez support@lobbystack.com."],
        },
      ],
    },
  },
} satisfies Record<"fr", Record<LegalKind, {
  updated: string
  h1: string
  intro: string
  notice: string
  nav: Array<[string, string]>
  sections: Array<{ id: string; title: string; paragraphs: string[] }>
}>>

const t = legalCopy.fr[kind]
---

<Layout
  seo={{
    title: routeSeo?.title,
    description: routeSeo?.description,
    canonicalPath,
    noindex: true,
    locale,
    jsonLd: [
      organizationJsonLd({ locale }),
      breadcrumbJsonLd([
        { name: copy.common.home, path: localizePath(locale, "/") },
        { name: t.h1, path: canonicalPath },
      ]),
      {
        "@context": "https://schema.org",
        "@type": "WebPage",
        "@id": absoluteUrl(`${canonicalPath}#webpage`),
        name: routeSeo?.title,
        url: absoluteUrl(canonicalPath),
        description: routeSeo?.description,
        inLanguage: locale,
      },
    ],
  }}
>
  <Navbar locale={locale} />
  <main id="main-content" class="bg-background text-foreground">
    <section class="border-b border-border/60">
      <div class="mx-auto max-w-4xl px-6 py-16 md:py-20">
        <p class="text-sm font-medium text-muted-foreground">{t.updated}</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight md:text-5xl">
          {t.h1}
        </h1>
        <p
          class="mt-6 max-w-3xl text-base leading-7 text-muted-foreground md:text-lg"
        >
          {t.intro}
        </p>
        <p class="mt-4 max-w-3xl text-sm leading-6 text-muted-foreground">
          {t.notice}
        </p>
      </div>
    </section>

    <section
      class="mx-auto grid max-w-6xl gap-10 px-6 py-12 md:grid-cols-[220px_1fr] md:py-16"
    >
      <aside class="hidden md:block">
        <nav class="sticky top-8 space-y-2 text-sm text-muted-foreground">
          {t.nav.map(([id, label]) => (
            <a class="block hover:text-foreground" href={`#${id}`}>
              {label}
            </a>
          ))}
        </nav>
      </aside>

      <article class="legal-copy max-w-none">
        {t.sections.map((section) => (
          <section id={section.id}>
            <h2>{section.title}</h2>
            {section.paragraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </section>
        ))}
      </article>
    </section>
  </main>
  <Footer locale={locale} />
</Layout>
