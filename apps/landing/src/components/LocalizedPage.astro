---
import Layout from "@/layouts/main.astro"
import { Navbar } from "@/components/Navbar"
import { Footer } from "@/components/Footer"
import { buttonVariants } from "@/components/ui/button"
import type { FrenchPage } from "@/lib/fr-pages"
import { localizeHref, localizePath } from "@/lib/i18n"
import { cn } from "@/lib/utils"
import { ArrowRight, Check } from "lucide-react"
import {
  breadcrumbJsonLd,
  faqPageJsonLd,
  organizationJsonLd,
  webPageJsonLd,
  webSiteJsonLd,
} from "@/lib/seo"

interface Props {
  page: FrenchPage
}

const { page } = Astro.props
const locale = "fr"
const canonicalPath = localizePath(locale, page.path)
const primaryHref = page.primaryHref ?? "https://app.lobbystack.com/signup"
const secondaryHref = page.secondaryHref ?? "/pricing/"
const primaryCta = page.primaryCta ?? "Essayer gratuitement"
const secondaryCta = page.secondaryCta ?? "Voir les tarifs"
const faqJsonLd = page.faqs?.length
  ? faqPageJsonLd({
      path: canonicalPath,
      faqs: page.faqs.map((faq) => ({
        question: faq.question,
        answer: faq.answer,
      })),
    })
  : undefined
---

<Layout
  seo={{
    title: page.title,
    description: page.description,
    canonicalPath,
    noindex: page.noindex,
    image: page.image,
    imageAlt: page.imageAlt ?? page.title,
    locale,
    jsonLd: [
      organizationJsonLd(),
      webSiteJsonLd(),
      breadcrumbJsonLd([
        { name: "Accueil", path: "/fr/" },
        { name: page.h1, path: canonicalPath },
      ]),
      webPageJsonLd({
        title: page.title,
        description: page.description,
        path: canonicalPath,
      }),
      ...(faqJsonLd ? [faqJsonLd] : []),
    ],
  }}
>
  <Navbar locale={locale} />
  <main id="main-content" class="min-h-screen bg-background text-foreground">
    <section
      class="mx-auto max-w-7xl px-6 pt-16 pb-12 md:pt-20 md:pb-16 lg:pt-24"
    >
      <div
        class="grid gap-12 lg:grid-cols-[minmax(0,1.05fr)_minmax(320px,0.95fr)] lg:items-center"
      >
        <div class="min-w-0">
          {page.eyebrow && <p class="eyebrow-label mb-5">{page.eyebrow}</p>}
          <h1 class="display-heading">{page.h1}</h1>
          <p class="body-copy mt-6 max-w-[65ch] md:text-lg">{page.intro}</p>
          {
            page.legalNotice && (
              <p class="mt-5 rounded-2xl border border-border/70 bg-muted/30 p-4 text-sm leading-6 text-muted-foreground">
                {page.legalNotice}
              </p>
            )
          }
          <div class="mt-8 flex flex-wrap items-center gap-4">
            <a
              href={localizeHref(locale, primaryHref)}
              class={cn(
                buttonVariants({ size: "lg" }),
                "h-11 rounded-full px-7 text-sm"
              )}
              data-ph-signup-cta
              data-ph-capture-attribute-section="fr_page_hero"
              data-ph-capture-attribute-action="primary_cta"
              data-ph-capture-attribute-destination={primaryHref}
            >
              {primaryCta}
              <ArrowRight className="ml-1 size-4" aria-hidden="true" />
            </a>
            <a
              href={localizeHref(locale, secondaryHref)}
              class="inline-flex h-11 items-center justify-center rounded-full border border-border/70 bg-background px-7 text-sm font-medium text-foreground transition-colors hover:bg-muted"
            >
              {secondaryCta}
            </a>
          </div>
        </div>

        <div
          class="rounded-[1.35rem] border border-border/70 bg-muted/30 p-6 md:p-8"
        >
          <p
            class="text-xs font-medium tracking-wide text-muted-foreground uppercase"
          >
            LobbyStack en français
          </p>
          <div class="mt-6 grid gap-3">
            {
              (page.cards ?? []).slice(0, 3).map((card) => (
                <article class="rounded-2xl border border-border/70 bg-background p-5">
                  <h2 class="font-heading text-lg font-medium tracking-tight">
                    {card.title}
                  </h2>
                  <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                    {card.body}
                  </p>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    {
      page.cards && page.cards.length > 3 && (
        <section class="border-t border-border/40 bg-muted/15 py-16 md:py-20">
          <div class="mx-auto max-w-7xl px-6">
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {page.cards.slice(3).map((card) => (
                <article class="rounded-2xl border border-border/70 bg-background p-6">
                  <h2 class="font-heading text-xl font-medium tracking-tight">
                    {card.title}
                  </h2>
                  <p class="mt-4 text-sm leading-relaxed text-muted-foreground">
                    {card.body}
                  </p>
                </article>
              ))}
            </div>
          </div>
        </section>
      )
    }

    {
      page.sections && (
        <section class="section-spacing">
          <div class="mx-auto flex max-w-7xl flex-col gap-12 px-6 md:gap-16">
            {page.sections.map((section) => (
              <article class="grid gap-8 border-t border-border/60 pt-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
                <h2 class="section-heading text-left">{section.heading}</h2>
                <div>
                  <p class="body-copy max-w-[68ch] md:text-lg">
                    {section.body}
                  </p>
                  {section.bullets && (
                    <ul class="mt-6 grid gap-3">
                      {section.bullets.map((bullet) => (
                        <li class="flex items-start gap-3 text-sm leading-relaxed text-muted-foreground">
                          <span class="mt-1 flex size-5 shrink-0 items-center justify-center rounded-full bg-foreground/5">
                            <Check
                              className="size-3.5 text-foreground/80"
                              aria-hidden="true"
                            />
                          </span>
                          <span>{bullet}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      page.faqs && (
        <section class="border-t border-border/40 bg-muted/10 py-16 md:py-20">
          <div class="mx-auto max-w-3xl px-6">
            <h2 class="section-heading text-center">Questions fréquentes</h2>
            <div class="mt-10 divide-y divide-border/70 rounded-2xl border border-border/70 bg-background">
              {page.faqs.map((faq) => (
                <article class="p-6">
                  <h3 class="font-heading text-lg font-medium tracking-tight">
                    {faq.question}
                  </h3>
                  <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                    {faq.answer}
                  </p>
                </article>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <section class="mx-auto max-w-3xl px-6 py-20 text-center md:py-24">
      <h2 class="section-heading">Prêt à couvrir vos appels?</h2>
      <p class="section-intro mx-auto max-w-[56ch]">
        Commencez avec les minutes incluses, puis passez à Pro quand votre
        volume d'appels augmente.
      </p>
      <div class="mt-8">
        <a
          href={primaryHref}
          class={cn(
            buttonVariants({ size: "lg" }),
            "h-11 rounded-full px-7 text-sm"
          )}
        >
          {primaryCta}
          <ArrowRight className="ml-1 size-4" aria-hidden="true" />
        </a>
      </div>
      <p class="fine-print mt-3">
        Aucune carte bancaire requise · Annulation possible à tout moment
      </p>
    </section>
  </main>
  <Footer locale={locale} />
</Layout>
