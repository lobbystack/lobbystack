---
import Layout from "@/layouts/main.astro"
import { Navbar } from "@/components/Navbar"
import { Footer } from "@/components/Footer"
import { buttonVariants } from "@/components/ui/button"
import { cn } from "@/lib/utils"
import {
  absoluteUrl,
  breadcrumbJsonLd,
  organizationJsonLd,
  webSiteJsonLd,
} from "@/lib/seo"
import { ArrowRight } from "lucide-react"

const title = "AI Receptionist Solutions | LobbyStack"
const description =
  "Explore LobbyStack AI receptionist solutions for phone answering, appointment scheduling, after-hours coverage, home services, dental offices, salons, and self-hosted deployments."
const canonicalPath = "/solutions/"

const solutions = [
  {
    title: "AI phone answering",
    href: "/solutions/ai-phone-answering/",
    description:
      "Answer calls, capture caller details, book appointments, and route requests based on your rules.",
  },
  {
    title: "AI appointment scheduler",
    href: "/solutions/ai-appointment-scheduler/",
    description:
      "Turn booking calls into scheduled appointments with confirmations and team notifications.",
  },
  {
    title: "Home services",
    href: "/solutions/ai-receptionist-for-home-services/",
    description:
      "Book HVAC, plumbing, electrical, roofing, landscaping, and other service calls while crews work.",
  },
  {
    title: "After-hours answering",
    href: "/solutions/after-hours-answering-service/",
    description:
      "Cover calls when your team is busy, closed, or unavailable without staffing another shift.",
  },
  {
    title: "Dental offices",
    href: "/solutions/ai-receptionist-for-dental-offices/",
    description:
      "Answer patient calls, book appointments, handle routine questions, and route urgent calls by your rules.",
  },
  {
    title: "Salons and spas",
    href: "/solutions/ai-receptionist-for-salons-and-spas/",
    description:
      "Book clients, answer service questions, and handle reschedules while providers stay with clients.",
  },
  {
    title: "Self-hosted AI receptionist",
    href: "/solutions/self-hosted-ai-receptionist/",
    description:
      "Run LobbyStack on infrastructure you control when your team needs deployment and data-control flexibility.",
  },
  {
    title: "Open-source AI receptionist",
    href: "/solutions/open-source-ai-receptionist/",
    description:
      "Audit the call handling logic, customize prompts and routing, and deploy on your own infrastructure.",
  },
]

const trades = [
  { title: "Plumbers", href: "/solutions/ai-receptionist-for-plumbers/" },
  { title: "HVAC", href: "/solutions/ai-receptionist-for-hvac/" },
  { title: "Electricians", href: "/solutions/ai-receptionist-for-electricians/" },
  { title: "Garage door repair", href: "/solutions/ai-receptionist-for-garage-door-repair/" },
  { title: "Appliance repair", href: "/solutions/ai-receptionist-for-appliance-repair/" },
  { title: "Restoration", href: "/solutions/ai-receptionist-for-restoration-companies/" },
  { title: "Locksmiths", href: "/solutions/ai-receptionist-for-locksmiths/" },
]

const comparisons = [
  {
    title: "AI receptionist vs virtual receptionist",
    href: "/compare/ai-receptionist-vs-virtual-receptionist/",
    description:
      "Understand when AI, human, or a hybrid approach fits your call answering needs.",
  },
  {
    title: "AI receptionist vs voicemail",
    href: "/compare/ai-receptionist-vs-voicemail/",
    description:
      "See how an AI receptionist captures revenue that voicemail loses.",
  },
]
---

<Layout
  seo={{
    title,
    description,
    canonicalPath,
    image: "/illustrations/industry-bookings.webp",
    imageAlt:
      "LobbyStack AI receptionist solutions for phone answering and appointment booking",
    jsonLd: [
      organizationJsonLd(),
      webSiteJsonLd(),
      breadcrumbJsonLd([
        { name: "Home", path: "/" },
        { name: "Solutions", path: canonicalPath },
      ]),
      {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "@id": absoluteUrl(`${canonicalPath}#webpage`),
        name: title,
        url: absoluteUrl(canonicalPath),
        description,
        isPartOf: {
          "@id": absoluteUrl("/#website"),
        },
      },
    ],
  }}
>
  <Navbar />
  <main class="min-h-screen bg-background text-foreground">
    <section class="mx-auto max-w-7xl px-6 py-20 md:py-28">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="display-heading">AI receptionist solutions</h1>
        <p class="body-copy mx-auto mt-6 max-w-[65ch] md:text-lg">
          Choose the LobbyStack call workflow that matches how your business
          answers phones, books appointments, routes calls, and follows up with
          customers.
        </p>
        <p
          class="mx-auto mt-4 max-w-[58ch] text-sm leading-relaxed text-muted-foreground"
        >
          These pages use the same product capabilities listed on the <a
            href="/features/"
            class="font-medium text-foreground underline underline-offset-4"
            >features page</a
          >: call answering, appointment booking, transfers, notifications,
          summaries, transcripts, outbound follow-up, and call history.
        </p>
      </div>

      <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          solutions.map((solution) => (
            <a
              href={solution.href}
              class="group flex min-h-56 flex-col rounded-2xl border border-border/70 bg-background p-6 shadow-[0_10px_30px_rgba(0,0,0,0.02)] transition-colors hover:bg-muted/40"
            >
              <h2 class="text-xl font-medium tracking-tight text-foreground">
                {solution.title}
              </h2>
              <p class="mt-4 text-sm leading-relaxed text-muted-foreground">
                {solution.description}
              </p>
              <span class="mt-auto inline-flex items-center gap-1 pt-6 text-sm font-medium text-foreground">
                View solution
                <ArrowRight className="size-3.5 transition-transform group-hover:translate-x-1" />
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="border-t border-border/40 bg-muted/15 py-20 md:py-24">
      <div class="mx-auto max-w-7xl px-6">
        <h2 class="section-heading text-center">AI receptionist for your trade</h2>
        <p class="body-copy mx-auto mt-6 max-w-[58ch] text-center">
          LobbyStack handles the call patterns that matter most in each trade: emergency screening, intake questions, booking, and after-hours routing.
        </p>
        <div class="mt-12 flex flex-wrap justify-center gap-3">
          {
            trades.map((trade) => (
              <a
                href={trade.href}
                class="inline-flex h-10 items-center rounded-full border border-border/70 bg-background px-5 text-sm font-medium text-foreground transition-colors hover:bg-muted"
              >
                {trade.title}
              </a>
            ))
          }
          <a
            href="/solutions/after-hours-answering-service-for-contractors/"
            class="inline-flex h-10 items-center rounded-full border border-border/70 bg-background px-5 text-sm font-medium text-foreground transition-colors hover:bg-muted"
          >
            Contractor after-hours
          </a>
        </div>
      </div>
    </section>

    <section class="py-20 md:py-24">
      <div class="mx-auto max-w-7xl px-6">
        <h2 class="section-heading text-center">Comparisons</h2>
        <p class="body-copy mx-auto mt-6 max-w-[58ch] text-center">
          Not sure whether an AI receptionist is right for your situation? These comparisons break down the tradeoffs honestly.
        </p>
        <div class="mx-auto mt-12 grid max-w-3xl gap-6">
          {
            comparisons.map((comparison) => (
              <a
                href={comparison.href}
                class="group flex flex-col rounded-2xl border border-border/70 bg-background p-6 shadow-[0_10px_30px_rgba(0,0,0,0.02)] transition-colors hover:bg-muted/40"
              >
                <h3 class="text-lg font-medium tracking-tight text-foreground">
                  {comparison.title}
                </h3>
                <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                  {comparison.description}
                </p>
                <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-foreground">
                  Read comparison
                  <ArrowRight className="size-3.5 transition-transform group-hover:translate-x-1" />
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-t border-border/40 bg-muted/15 py-20 md:py-24">
      <div
        class="mx-auto grid max-w-7xl gap-10 px-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-center"
      >
        <div>
          <h2 class="section-heading text-left">
            One phone layer for multiple business workflows
          </h2>
          <p class="body-copy mt-5 max-w-[58ch]">
            LobbyStack can answer calls, step in when your team is unavailable,
            book appointments, collect caller details, route requests, and send
            summaries based on the rules you set.
          </p>
          <a
            href="/features/"
            class="mt-6 inline-flex text-sm font-medium text-foreground underline underline-offset-4"
          >
            See the full feature list
          </a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-2xl border border-border/70 bg-background p-6">
            <h3 class="font-medium tracking-tight">For service teams</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
              Capture job details, service area, urgency, and scheduling needs,
              then notify the right person with a clear summary.
            </p>
          </div>
          <div class="rounded-2xl border border-border/70 bg-background p-6">
            <h3 class="font-medium tracking-tight">
              For appointment businesses
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
              Let callers book, receive confirmation texts, reschedule when your
              rules allow it, or request a callback.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-3xl px-6 py-20 text-center md:py-24">
      <h2 class="section-heading">Start with your busiest call path</h2>
      <p class="section-intro mx-auto mt-5 max-w-[58ch]">
        Try LobbyStack on the calls your team misses most often, then expand to
        after-hours coverage, scheduling, transfers, and follow-up as your
        workflow matures.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/pricing/"
          class={cn(buttonVariants({ size: "lg" }), "rounded-full px-7")}
        >
          See pricing
          <ArrowRight className="ml-1 size-4" />
        </a>
        <a
          href="/features/"
          class="inline-flex h-11 items-center justify-center rounded-full border border-border/70 bg-background px-7 text-sm font-medium text-foreground transition-colors hover:bg-muted"
        >
          View features
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
