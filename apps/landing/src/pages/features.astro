---
import Layout from "@/layouts/main.astro"
import { Navbar } from "@/components/Navbar"
import { FeaturesHero } from "@/components/features/FeaturesHero"
import { FeatureWall } from "@/components/features/FeatureWall"
import { IncludedOnEveryPlan } from "@/components/features/IncludedOnEveryPlan"
import { FeaturesCtaSection } from "@/components/features/FeaturesCtaSection"
import { Footer } from "@/components/Footer"
import {
  breadcrumbJsonLd,
  organizationJsonLd,
  webSiteJsonLd,
  absoluteUrl,
} from "@/lib/seo"

const title = "AI Receptionist Features for Calls, SMS, and Booking"
const description =
  "Explore LobbyStack AI receptionist features for phone answering, SMS, appointment booking, call routing, lead qualification, follow-up, and summaries."
---

<Layout
  seo={{
    title,
    description,
    canonicalPath: "/features/",
    jsonLd: [
      organizationJsonLd(),
      webSiteJsonLd(),
      breadcrumbJsonLd([
        { name: "Home", path: "/" },
        { name: "Features", path: "/features/" },
      ]),
      {
        "@context": "https://schema.org",
        "@type": "WebPage",
        "@id": absoluteUrl("/features/#webpage"),
        name: title,
        url: absoluteUrl("/features/"),
        description,
        isPartOf: {
          "@id": absoluteUrl("/#website"),
        },
      },
    ],
  }}
>
  <Navbar />
  <main>
    <FeaturesHero />
    <FeatureWall />
    <IncludedOnEveryPlan />
    <FeaturesCtaSection />
  </main>
  <Footer />
</Layout>
