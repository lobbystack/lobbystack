---
import LocalizedPage from "@/components/LocalizedPage.astro"
import { frenchPageByPath, frenchStaticPaths } from "@/lib/fr-pages"
import { normalizedPath } from "@/lib/seo"

export function getStaticPaths() {
  return frenchStaticPaths
    .filter((path) => path !== "/")
    .map((path) => ({
      params: { slug: path.replace(/^\/|\/$/g, "") },
      props: { path },
    }))
}

const path = normalizedPath(Astro.props.path)
const page = frenchPageByPath(path)
if (!page) throw new Error(`Missing French page for ${path}`)
---

<LocalizedPage page={page} />
