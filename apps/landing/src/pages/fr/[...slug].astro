---
import SeoLandingPage from "@/components/SeoLandingPage.astro"
import {
  getLocalizedSeoLandingPage,
  localizedSeoLandingPages,
} from "@/lib/localized-seo-landing-pages"
import { normalizedPath } from "@/lib/seo"

export function getStaticPaths() {
  const explicitFrenchRoutes = new Set([
    "/",
    "/features/",
    "/pricing/",
    "/solutions/",
    "/solutions/ai-phone-answering/",
    "/solutions/ai-appointment-scheduler/",
    "/solutions/ai-receptionist-for-home-services/",
  ])

  return localizedSeoLandingPages("fr")
    .map((page) => page.path)
    .filter((path) => !explicitFrenchRoutes.has(path))
    .map((path) => ({
      params: { slug: path.replace(/^\/|\/$/g, "") },
      props: { path },
    }))
}

const path = normalizedPath(Astro.props.path)
const page = getLocalizedSeoLandingPage("fr", path)
if (!page) throw new Error(`Missing shared SEO page for French path ${path}`)
---

<SeoLandingPage page={page} locale="fr" />
