---
import Layout from "@/layouts/main.astro"
import { Navbar } from "@/components/Navbar"
import { HeroSection } from "@/components/HeroSection"
import { LobbyStackHeroVoiceDemo } from "@/components/web-voice/LobbyStackWebVoiceWidget"
import { FeatureGrid } from "@/components/FeatureGrid"
import {
  ProductExtensionSection,
  LandingPageAdditions,
} from "@/components/LandingPageAdditions"

import { FaqSection } from "@/components/FaqSection"
import { CtaSection } from "@/components/CtaSection"
import { Footer } from "@/components/Footer"
import { CalDemoModal } from "@/components/CalDemoModal"
import { homeFaqs } from "@/lib/home-faqs"
import {
  faqPageJsonLd,
  organizationJsonLd,
  softwareApplicationJsonLd,
  webSiteJsonLd,
} from "@/lib/seo"
---

<Layout
  seo={{
    canonicalPath: "/",
    image: "/og/lobbystack-og.webp",
    imageAlt:
      "LobbyStack open-source AI receptionist dashboard and product logo",
    imageWidth: 1200,
    imageHeight: 630,
    jsonLd: [
      organizationJsonLd(),
      webSiteJsonLd(),
      softwareApplicationJsonLd(),
      faqPageJsonLd({ path: "/", faqs: homeFaqs }),
    ],
  }}
>
  <Navbar />
  <main id="main-content">
    <HeroSection>
      <LobbyStackHeroVoiceDemo client:idle />
    </HeroSection>
    <ProductExtensionSection />
    <FeatureGrid />
    <LandingPageAdditions />
    <FaqSection />
    <CtaSection />
  </main>
  <Footer showTaaftBadge />
  <CalDemoModal client:load />
</Layout>
