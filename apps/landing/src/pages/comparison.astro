---
import Layout from "@/layouts/main.astro"
import { Navbar } from "@/components/Navbar"
import { Footer } from "@/components/Footer"
import { APP_SIGNUP_URL } from "@/lib/app-links"
import { buttonVariants } from "@/components/ui/button"
import { cn } from "@/lib/utils"
import {
  breadcrumbJsonLd,
  organizationJsonLd,
  webSiteJsonLd,
  webPageJsonLd,
} from "@/lib/seo"
import { ArrowRight } from "lucide-react"

const title = "AI Receptionist Comparison Guide"
const description =
  "Compare LobbyStack AI receptionist against voicemail, virtual receptionists, and more. Understand which call answering approach works best for your business."
const canonicalPath = "/comparison/"

const comparisons = [
  {
    title: "AI receptionist vs voicemail",
    href: "/compare/ai-receptionist-vs-voicemail/",
    bestFor: "Businesses losing ready-to-book callers after hours or during busy periods.",
    description:
      "See how an AI receptionist captures revenue that voicemail loses. Every unanswered call is a booking or a lead that a recording cannot close.",
  },
  {
    title: "AI vs virtual receptionist",
    href: "/compare/ai-receptionist-vs-virtual-receptionist/",
    bestFor: "Operators comparing human answering services against AI coverage and handoff.",
    description:
      "Understand when AI, human, or a hybrid approach fits your call answering needs. Compare availability, cost scaling, and caller experience.",
  },
]

const decisionFactors = [
  {
    title: "Availability",
    body: "If callers reach you after hours, on weekends, or while your team is already serving customers, the main question is whether the alternative can answer immediately without adding staff.",
  },
  {
    title: "Booking speed",
    body: "For service businesses, the best option is the one that turns the call into a confirmed appointment before the caller starts looking for another provider.",
  },
  {
    title: "Cost control",
    body: "Some answering options look inexpensive until call volume grows. Compare monthly cost, minute charges, spam handling, and the cost of missed opportunities.",
  },
  {
    title: "Escalation safety",
    body: "Routine calls should be handled automatically, but urgent, sensitive, or high-value calls need a clear path back to a human with context attached.",
  },
]

const scenarios = [
  "A homeowner calls after closing because a pipe burst, an outlet is sparking, or a garage door will not open.",
  "A patient, client, or customer wants to book while your front desk is already on another call.",
  "A lead from Google Business Profile is ready to schedule now, but they will call the next result if they hit voicemail.",
  "A small team wants professional phone coverage without hiring another receptionist or committing to an expensive answering service.",
]
---

<Layout
  seo={{
    title,
    description,
    canonicalPath,
    jsonLd: [
      organizationJsonLd(),
      webSiteJsonLd(),
      breadcrumbJsonLd([
        { name: "Home", path: "/" },
        { name: "Comparison", path: canonicalPath },
      ]),
      webPageJsonLd({
        title,
        description,
        path: canonicalPath,
        type: "CollectionPage",
      }),
    ],
  }}
>
  <Navbar />
  <main class="min-h-screen bg-background text-foreground">
    {/* ── Hero ── */}
    <section class="mx-auto max-w-7xl px-6 pt-20 md:pt-28">
      <div class="pb-8 md:pb-12">
        <div class="mx-auto max-w-4xl text-center">
          <p class="eyebrow-label">Comparison guide</p>
          <h1 class="mx-auto mt-5 display-heading max-w-[18ch]">
            How LobbyStack compares to{" "}
            <span class="underline decoration-2 underline-offset-4">
              alternatives
            </span>
          </h1>
          <p class="body-copy mx-auto mt-6 max-w-[65ch] md:text-lg">
            Every business needs reliable call answering. The right approach
            depends on your call volume, budget, and how much you value
            converting every caller into a booking. These comparisons help you
            decide.
          </p>
          <div class="mt-8">
            <a
              href={APP_SIGNUP_URL}
              class={cn(buttonVariants({ size: "lg" }), "rounded-full px-7")}
              data-ph-signup-cta
              data-ph-capture-attribute-section="comparison_hero"
              data-ph-capture-attribute-action="try_for_free"
              data-ph-capture-attribute-destination={APP_SIGNUP_URL}
            >
              Try for free
              <ArrowRight className="ml-1 size-4" />
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* ── Comparison cards ── */}
    <section class="mx-auto max-w-5xl px-6 pt-16 md:pt-20">
      <div class="grid gap-6 md:grid-cols-2">
        {
          comparisons.map((comparison, i) => (
            <a
              href={comparison.href}
              class="group flex flex-col rounded-2xl border border-border/70 bg-background p-8 transition-colors hover:bg-muted/30 md:p-10"
            >
              <div class="flex items-start justify-between gap-4">
                <span class="font-mono text-xs font-medium tracking-wider text-muted-foreground uppercase">
                  0{i + 1}
                </span>
                <ArrowRight className="mt-0.5 size-4 shrink-0 text-muted-foreground transition-all group-hover:translate-x-1 group-hover:text-foreground" />
              </div>
              <h2 class="mt-6 card-heading text-foreground">
                {comparison.title}
              </h2>
              <p class="mt-4 text-sm leading-relaxed text-muted-foreground md:text-base">
                {comparison.description}
              </p>
              <p class="mt-6 border-t border-border/60 pt-5 text-sm leading-relaxed text-muted-foreground">
                <span class="font-medium text-foreground">Best for:</span>{" "}
                {comparison.bestFor}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    {/* ── Context ── */}
    <section class="mx-auto max-w-5xl px-6 pt-20 md:pt-24">
      <div class="grid gap-8 md:grid-cols-2 md:gap-12">
        <p class="text-base leading-relaxed text-muted-foreground md:text-lg">
          Most phone-answering choices sound similar until a customer calls at
          the wrong moment. Voicemail records a message. A human answering
          service can help, but cost and availability depend on active agents.
          LobbyStack uses an AI receptionist to answer immediately, collect the
          right details, book appointments, and transfer urgent calls back to
          your team with context.
        </p>
        <p class="text-base leading-relaxed text-muted-foreground md:text-lg">
          These comparisons focus on the questions small businesses actually ask
          before switching: Will callers wait? Can it book appointments? What
          happens after hours? How predictable is the cost? When should a human
          take over? Use this guide as the starting point, then read the
          detailed pages for the tradeoffs behind each alternative.
        </p>
      </div>
    </section>

    {/* ── Decision criteria ── */}
    <section class="mx-auto max-w-5xl px-6 pt-20 md:pt-24">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-5">
          <h2 class="section-heading text-left">
            How to compare call answering options
          </h2>
          <p class="body-copy mt-5 max-w-[52ch] md:text-lg">
            The right phone coverage depends less on whether the solution is AI,
            human, or voicemail, and more on what happens during the first two
            minutes of a call. A useful comparison should follow the caller
            from first ring to final outcome.
          </p>
        </div>
        <div class="grid gap-8 sm:grid-cols-2 lg:col-span-7">
          {
            decisionFactors.map((factor, i) => (
              <div class="border-t border-border/70 pt-6">
                <div class="flex items-baseline gap-3">
                  <span class="font-mono text-xs font-medium tracking-wider text-muted-foreground">
                    0{i + 1}
                  </span>
                  <h3 class="text-base font-medium tracking-tight text-foreground">
                    {factor.title}
                  </h3>
                </div>
                <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                  {factor.body}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* ── Common situations ── */}
    <section class="mx-auto max-w-4xl px-6 pt-20 md:pt-24">
      <div class="border-t border-border/40 pt-16 md:pt-20">
        <h2 class="section-heading text-center">
          Common situations these comparisons cover
        </h2>
        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          {
            scenarios.map((scenario) => (
              <div class="flex gap-3 rounded-xl border border-border/60 bg-background p-5">
                <span class="mt-1.5 size-1.5 shrink-0 rounded-full bg-foreground/25" />
                <p class="text-sm leading-relaxed text-muted-foreground">
                  {scenario}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* ── More comparisons note ── */}
    <section class="mx-auto max-w-2xl px-6 pt-16 text-center md:pt-20">
      <p class="text-sm leading-relaxed text-muted-foreground">
        More head-to-head comparisons are on the way. If there is a specific
        tool or approach you would like to see compared, let us know at{" "}
        <a
          href="mailto:support@lobbystack.com"
          class="font-medium text-foreground underline underline-offset-4"
        >
          support@lobbystack.com
        </a>.
      </p>
    </section>

    {/* ── Final CTA ── */}
    <section class="mt-20 border-t border-border/40 bg-muted/15 py-20 md:mt-24 md:py-24">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="section-heading">
          Ready to try LobbyStack yourself?
        </h2>
        <p class="section-intro mx-auto max-w-[58ch]">
          Comparisons help you decide. Demos let you experience it. Start for
          free and see how LobbyStack handles actual calls to your business.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
          <a
            href="/pricing/"
            class={cn(buttonVariants({ size: "lg" }), "rounded-full px-7")}
          >
            See pricing
            <ArrowRight className="ml-1 size-4" />
          </a>
          <a
            href="/features/"
            class="inline-flex h-11 items-center justify-center rounded-full border border-border/70 bg-background px-7 text-sm font-medium text-foreground transition-colors hover:bg-muted"
          >
            View features
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
