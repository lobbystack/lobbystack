---
import Layout from "@/layouts/main.astro"
import { Navbar } from "@/components/Navbar"
import { Footer } from "@/components/Footer"
import { getCollection, render } from "astro:content"
import {
  blogJsonLd,
  blogPostingJsonLd,
  breadcrumbJsonLd,
  imageObjectJsonLd,
  organizationJsonLd,
  plainTextFromMarkdown,
  webSiteJsonLd,
} from "@/lib/seo"
import { APP_SIGNUP_URL } from "@/lib/app-links"

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog")
  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content } = await render(entry)

// Fetch latest posts for the sidebar
const allPosts = await getCollection("blog")
const latestPosts = allPosts
  .filter((p) => p.id !== entry.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)

const canonicalPath = `/blog/${entry.id}/`
const publishedTime = entry.data.pubDate.toISOString()
const articleBody = plainTextFromMarkdown(entry.body)
---

<Layout
  seo={{
    title: `${entry.data.title} - AI Receptionist Blog`,
    description: entry.data.description,
    canonicalPath,
    image: entry.data.coverImage,
    imageAlt: entry.data.title,
    type: "article",
    publishedTime,
    modifiedTime: publishedTime,
    author: entry.data.author,
    jsonLd: [
      organizationJsonLd(),
      webSiteJsonLd(),
      blogJsonLd(),
      imageObjectJsonLd({
        path: canonicalPath,
        image: entry.data.coverImage,
        alt: entry.data.title,
        width: 1672,
        height: 941,
      }),
      blogPostingJsonLd({
        title: entry.data.title,
        description: entry.data.description,
        path: canonicalPath,
        image: entry.data.coverImage,
        author: entry.data.author,
        publishedTime,
        modifiedTime: publishedTime,
        articleBody,
        category: entry.data.category,
      }),
      breadcrumbJsonLd([
        { name: "Home", path: "/" },
        { name: "Blog", path: "/blog/" },
        { name: entry.data.title, path: canonicalPath },
      ]),
    ],
  }}
>
  <Navbar />

  <article
    id="main-content"
    class="min-h-screen bg-background pb-24 text-foreground"
  >
    <div class="mx-auto max-w-7xl px-6 pt-24">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-24">
        {/* Left Column: Article Content */}
        <div class="lg:col-span-8">
          <header class="mb-10">
            <h1 class="display-heading mb-6 text-foreground">
              {entry.data.title}
            </h1>

            <div class="flex items-center gap-4">
              {
                entry.data.category && (
                  <span class="rounded-md border border-border/60 px-2.5 py-1 font-mono text-[0.6875rem] text-muted-foreground">
                    {entry.data.category}
                  </span>
                )
              }
              <time
                class="text-xs font-medium text-muted-foreground"
                datetime={entry.data.pubDate.toISOString()}
              >
                {
                  entry.data.pubDate.toLocaleDateString("en-US", {
                    day: "numeric",
                    month: "short",
                    year: "numeric",
                  })
                }
              </time>
            </div>
          </header>

          {
            entry.data.coverImage && (
              <div class="mb-12 aspect-[16/9] overflow-hidden rounded-2xl border border-border/30 bg-muted shadow-sm md:aspect-[2/1]">
                <img
                  src={entry.data.coverImage}
                  alt={entry.data.title}
                  width="1672"
                  height="941"
                  class="h-full w-full object-cover"
                  decoding="async"
                  fetchpriority="high"
                />
              </div>
            )
          }

          <div class="blog-copy max-w-none">
            <Content />
          </div>
        </div>

        {/* Right Sidebar */}
        <div class="space-y-12 lg:col-span-4">
          <div>
            <h3
              class="mb-6 font-heading text-lg font-medium tracking-[-0.03em] text-foreground"
            >
              Product resources
            </h3>
            <div class="flex flex-col gap-3 text-sm">
              <a
                class="rounded-xl border border-border/50 bg-card px-4 py-3 text-foreground transition-colors hover:bg-muted/40"
                href="/pricing/"
                data-ph-capture-attribute-section="blog_sidebar"
                data-ph-capture-attribute-action="view_pricing"
                data-ph-capture-attribute-destination="/pricing/"
              >
                Compare LobbyStack pricing
              </a>
              <a
                class="rounded-xl border border-border/50 bg-card px-4 py-3 text-foreground transition-colors hover:bg-muted/40"
                href="/#how-it-works"
              >
                See how setup works
              </a>
              <a
                class="rounded-xl border border-border/50 bg-card px-4 py-3 text-foreground transition-colors hover:bg-muted/40"
                href="https://docs.lobbystack.com/introduction"
                target="_blank"
                rel="noopener noreferrer"
                data-ph-capture-attribute-section="blog_sidebar"
                data-ph-capture-attribute-action="view_help_center"
                data-ph-capture-attribute-destination="https://docs.lobbystack.com/introduction"
              >
                Read the help center
              </a>
            </div>
          </div>

          {/* Latest Posts */}
          {
            latestPosts.length > 0 && (
              <div>
                <h3 class="mb-6 font-heading text-lg font-semibold text-foreground">
                  Latest blog posts
                </h3>
                <div class="flex flex-col gap-4">
                  {latestPosts.map((post) => (
                    <a href={`/blog/${post.id}/`} class="group block">
                      <div class="rounded-2xl border border-border/50 bg-card p-5">
                        <time
                          class="mb-2 block text-[11px] font-medium text-muted-foreground"
                          datetime={post.data.pubDate.toISOString()}
                        >
                          {post.data.pubDate.toLocaleDateString("en-US", {
                            day: "numeric",
                            month: "short",
                            year: "numeric",
                          })}
                        </time>
                        <h4 class="font-heading text-sm leading-tight font-medium transition-colors group-hover:text-primary">
                          {post.data.title}
                        </h4>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )
          }
        </div>
      </div>

      {/* Blog Call to Action (Editorial, Cardless) */}
      <aside
        class="relative mt-20 border-t border-border/40 pt-20 pb-12 text-center md:mt-24 md:pt-24"
      >
        <div class="relative z-10 mx-auto max-w-4xl">
          <h2
            class="mb-8 font-heading text-5xl leading-[1.05] font-semibold tracking-tighter text-foreground md:text-6xl lg:text-7xl"
          >
            Never miss a <br class="hidden sm:block" />
            <span class="underline decoration-2 underline-offset-4"
              >ready-to-book</span
            > caller again.
          </h2>

          <p
            class="mx-auto mb-14 max-w-2xl text-xl leading-relaxed font-light text-muted-foreground md:text-2xl"
          >
            LobbyStack answers every call, qualifies new leads, and books
            appointments so your team can stay focused on the work.
          </p>

          <div
            class="flex flex-col items-center justify-center gap-5 sm:flex-row"
          >
            <a
              href={APP_SIGNUP_URL}
              data-ph-signup-cta
              data-ph-capture-attribute-section="blog_post_cta"
              data-ph-capture-attribute-action="try_for_free"
              data-ph-capture-attribute-destination={APP_SIGNUP_URL}
              class="inline-flex h-14 w-full items-center justify-center rounded-full border border-transparent bg-foreground px-10 text-base font-medium text-background transition-all duration-300 hover:scale-[1.02] hover:bg-foreground/90 sm:w-auto"
            >
              Start for free
            </a>
            <a
              href="/#how-it-works"
              class="inline-flex h-14 w-full items-center justify-center rounded-full border border-border/80 bg-background px-10 text-base font-medium text-foreground transition-all duration-300 hover:border-foreground hover:bg-muted/50 sm:w-auto"
            >
              See how it works
            </a>
          </div>
        </div>
      </aside>
    </div>
  </article>

  <Footer />
</Layout>
